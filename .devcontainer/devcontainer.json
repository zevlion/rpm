{
  "name": "rpm",
  "image": "mcr.microsoft.com/devcontainers/rust:1-bookworm",
  "customizations": {
    "vscode": {
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml"
      ],
      "settings": {
        "rust-analyzer.check.command": "clippy",
        "rust-analyzer.cargo.features": [
          "rt-multi-thread",
          "macros",
          "io-util",
          "fs",
          "sync",
          "time",
          "process",
          "net"
        ]
      }
    }
  },
  "postCreateCommand": "rustup component add clippy rustfmt && cargo install cargo-bloat",
}